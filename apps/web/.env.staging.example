# ===========================================
# apps/web/.env.staging — Binbang 스테이징 환경
# ===========================================
# 이 파일을 .env.staging으로 복사 후 실제 값 채우기
# common vars(DATABASE_URL/NEXTAUTH_SECRET/GOOGLE_*/KAKAO_*)는 루트 .env.staging에서 로드

NEXTAUTH_URL=https://staging.moodybeard.com

WORKER_INTERNAL_URL=http://worker:3500

# ─── Binbang: Agoda API ─────────────────────────────────────
# 방법 A: 각각 지정
BINBANG_AGODA_SITE_ID=
BINBANG_AGODA_API_KEY=
# 방법 B: 합산 (siteId:apiKey) — A, B 중 하나만 사용
# BINBANG_AGODA_AUTH=

# ─── Binbang: 내부 API 토큰 ─────────────────────────────────
# cron 트리거 및 internal API 인증용. 임의의 긴 문자열 사용
BINBANG_INTERNAL_API_TOKEN=

# ─── Binbang: 이메일 ────────────────────────────────────────
BINBANG_EMAIL_PROVIDER=resend          # console | resend
BINBANG_RESEND_API_KEY=re_xxx
BINBANG_FROM_EMAIL=Binbang <noreply@moodybeard.com>
BINBANG_UNSUBSCRIBE_SECRET=           # 미설정 시 NEXTAUTH_SECRET 사용

# ─── Binbang: 폴링 설정 ────────────────────────────────────
BINBANG_POLL_INTERVAL_MINUTES=30      # due 판정 간격
BINBANG_DUE_POLL_LIMIT=20            # 1회 cron당 최대 처리 숙소 수
BINBANG_DUE_POLL_CONCURRENCY=3       # 동시 폴링 수

# ─── Binbang: 감지 설정 ────────────────────────────────────
BINBANG_PRICE_DROP_THRESHOLD=0.1     # 전역 가격 하락 임계값 (10%, 숙소별 priceDropThreshold 미설정 시 사용)

# ─── Binbang: 쿨다운 설정 (Sprint 3) ───────────────────────
BINBANG_VACANCY_COOLDOWN_HOURS=24    # 동일 오퍼 빈방 알림 쿨다운 (시간)
BINBANG_PRICE_DROP_COOLDOWN_HOURS=6  # 동일 오퍼 가격 하락 알림 쿨다운 (시간)

# ─── Binbang: 스냅샷 보존 (Sprint 3) ───────────────────────
BINBANG_SNAPSHOT_RETENTION_DAYS=30   # 폴링 런/스냅샷 보존 일수 (cleanup cron 기준)

# ─── Binbang: 알림 발송 설정 ───────────────────────────────
BINBANG_NOTIFICATION_DISPATCH_LIMIT=50
BINBANG_NOTIFICATION_MAX_ATTEMPTS=5

# ─── Sentry ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
SENTRY_ENVIRONMENT=staging
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=web
