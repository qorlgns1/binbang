# ===========================================
# apps/web/.env.staging — MoonCatch 스테이징 환경
# ===========================================
# 이 파일을 .env.staging으로 복사 후 실제 값 채우기
# common vars(DATABASE_URL/NEXTAUTH_SECRET/GOOGLE_*/KAKAO_*)는 루트 .env.staging에서 로드

NEXTAUTH_URL=https://staging.moodybeard.com

WORKER_INTERNAL_URL=http://worker:3500

# ─── MoonCatch: Agoda API ─────────────────────────────────────
# 방법 A: 각각 지정
MOONCATCH_AGODA_SITE_ID=
MOONCATCH_AGODA_API_KEY=
# 방법 B: 합산 (siteId:apiKey) — A, B 중 하나만 사용
# MOONCATCH_AGODA_AUTH=

# ─── MoonCatch: 내부 API 토큰 ─────────────────────────────────
# cron 트리거 및 internal API 인증용. 임의의 긴 문자열 사용
MOONCATCH_INTERNAL_API_TOKEN=

# ─── MoonCatch: Vercel Cron ───────────────────────────────────
# vercel.json cron 인증용 (Docker 배포 시에는 외부 cron으로 대체 가능)
CRON_SECRET=

# ─── MoonCatch: 이메일 ────────────────────────────────────────
MOONCATCH_EMAIL_PROVIDER=resend          # console | resend
MOONCATCH_RESEND_API_KEY=re_xxx
MOONCATCH_FROM_EMAIL=MoonCatch <noreply@moodybeard.com>
MOONCATCH_UNSUBSCRIBE_SECRET=           # 미설정 시 NEXTAUTH_SECRET 사용

# ─── MoonCatch: 폴링 설정 ────────────────────────────────────
MOONCATCH_POLL_INTERVAL_MINUTES=30      # due 판정 간격
MOONCATCH_DUE_POLL_LIMIT=20            # 1회 cron당 최대 처리 숙소 수
MOONCATCH_DUE_POLL_CONCURRENCY=3       # 동시 폴링 수

# ─── MoonCatch: 감지 설정 ────────────────────────────────────
MOONCATCH_PRICE_DROP_THRESHOLD=0.1     # 전역 가격 하락 임계값 (10%, 숙소별 priceDropThreshold 미설정 시 사용)

# ─── MoonCatch: 쿨다운 설정 (Sprint 3) ───────────────────────
MOONCATCH_VACANCY_COOLDOWN_HOURS=24    # 동일 오퍼 빈방 알림 쿨다운 (시간)
MOONCATCH_PRICE_DROP_COOLDOWN_HOURS=6  # 동일 오퍼 가격 하락 알림 쿨다운 (시간)

# ─── MoonCatch: 스냅샷 보존 (Sprint 3) ───────────────────────
MOONCATCH_SNAPSHOT_RETENTION_DAYS=30   # 폴링 런/스냅샷 보존 일수 (cleanup cron 기준)

# ─── MoonCatch: 알림 발송 설정 ───────────────────────────────
MOONCATCH_NOTIFICATION_DISPATCH_LIMIT=50
MOONCATCH_NOTIFICATION_MAX_ATTEMPTS=5

# ─── Sentry ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
SENTRY_ENVIRONMENT=staging
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=web
