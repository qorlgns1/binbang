# ===========================================
# apps/web/.env.local example
# ===========================================
# NOTE: common vars(DATABASE_URL/NEXTAUTH_SECRET/GOOGLE_*/KAKAO_*) are read from root .env

# App-specific override (required)
NEXTAUTH_URL=http://localhost:3000

# Required if Google Form webhook endpoint is enabled
GOOGLE_FORM_WEBHOOK_SECRET=replace-with-random-secret

# Required for local docker compose
WEB_PORT=3000

# ─── Binbang: Agoda API (secret, env 필수) ────────────────
AGODA_AFFILIATE_SITE_ID=
AGODA_AFFILIATE_API_KEY=

# ─── Binbang: 내부 API 토큰 ───────────────────────────────
# cron 트리거 및 internal API 인증용. 임의의 긴 문자열 사용
BINBANG_INTERNAL_API_TOKEN=

# ─── Binbang: 이메일 시크릿 ──────────────────────────────────
# 이메일 provider / 발신자 주소는 Admin > Settings에서 관리
# Resend 사용 시에만 API 키 필요 (provider=console이면 불필요)
RESEND_API_KEY=
EMAIL_FROM=
BINBANG_UNSUBSCRIBE_SECRET=

# Optional: Awin affiliate API (Bearer token from https://ui.awin.com/awin-api)
# AWIN_API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional public metadata/analytics
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# ─── Sentry ──────────────────────────────────────
# DSN: Sentry 프로젝트 > Settings > Client Keys 에서 확인
# DSN은 공개해도 안전 (데이터 수집만 가능, 조회 불가)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# 환경 구분 (development / production). 미설정 시 NODE_ENV 사용
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_ENVIRONMENT=

# 소스맵 업로드 전용 — CI 빌드 서버에만 설정, 절대 커밋 금지
# Sentry > Settings > Auth Tokens 에서 발급
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=web

# PII 수집 opt-in — true로 설정 시 요청 헤더·사용자 IP를 Sentry에 전송 (기본값: false)
# GDPR/CCPA 준수 여부 확인 후 활성화
SENTRY_SEND_DEFAULT_PII=false
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
