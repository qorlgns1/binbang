{
  "name": "@workspace/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --experimental-next-config-strip-types",
    "build": "next build --experimental-next-config-strip-types",
    "start": "next start --experimental-next-config-strip-types",
    "lint": "biome lint .",
    "typecheck": "__NEXT_NODE_NATIVE_TS_LOADER_ENABLED=true next typegen && tsc --noEmit",
    "clean": "rm -rf .next node_modules",
    "test": "vitest run",
    "test:e2e:run": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --project=chromium --debug",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --project=chromium --ui",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --project=chromium --headed",
    "analyze": "ANALYZE=true next build --experimental-next-config-strip-types"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.100.8",
    "@workspace/db": "workspace:*",
    "@workspace/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-intl": "^4.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "3.8.1",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.8",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.2",
    "@playwright/test": "^1.59.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "vitest": "catalog:"
  }
}
